# SARKARI BABU - Developer API Keys Configuration
# Rename this file to .env and fill in your keys.

# Google Gemini API Key (Obtain a free key from Google AI Studio)
VITE_GEMINI_API_KEY=

# Groq API Key (Obtain a free key from Groq Console)
VITE_GROQ_API_KEY=

# OpenAI API Key (Obtain a key from OpenAI Platform Dashboard)
VITE_OPENAI_API_KEY=

# OpenRouter API Key (Obtain a key from OpenRouter Dashboard)
VITE_OPENROUTER_API_KEY=

